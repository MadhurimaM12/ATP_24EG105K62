Cookie: token=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJlbWFpbCI6InJhanVAZ21haWwuY29tIiwiaWF0IjoxNzczNDExMDEzLCJleHAiOjE3NzM0MTExMTN9.KuvW2ig3m5ruTbTDWkpRZFAGWrLNBpymtP51_0ushIQ; Path=/; HttpOnly; SameSite=Lax


